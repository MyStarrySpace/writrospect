// Prisma schema for Accountabili-Bot
// AI-assisted accountability journal system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum TimeContext {
  early_morning
  morning
  afternoon
  evening
  late_night
}

enum QuickEntryType {
  mood_check    // Quick emotional check-in
  done          // Something completed
  stuck         // Blocked on something
  thinking_of   // Pondering/considering
  quick_win     // Small accomplishment
  vent          // Emotional release
  planning      // Thinking ahead
  general       // No specific type
}

enum CommitmentStatus {
  active
  completed
  abandoned
  paused
}

enum MotivationType {
  intrinsic
  extrinsic
  obligation
  curiosity
  growth
  maintenance
}

enum RelationshipType {
  partner
  friend
  family
  coworker
  acquaintance
  other
}

enum Sentiment {
  positive
  neutral
  stressed
  conflicted
  negative
}

enum ComplexityPreference {
  simple
  moderate
  complex
  adaptive
}

enum InteractionMode {
  thinking_partner
  functional
  balanced
}

// User model - linked to Neon Auth (Stack Auth)
model User {
  id           String   @id @default(cuid())
  stackUserId  String   @unique // Links to neon_auth.users_sync table
  email        String
  timezone     String?  // IANA timezone (e.g., "America/New_York")
  profileImage String?  // URL to profile image (preset path or uploaded URL)
  bannerTheme  String?  // Theme preset ID (e.g., "zen-garden", "ocean-breeze")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  context     UserContext?
  successModel UserSuccessModel?
  preferences  UserEngagementPreferences?
  notificationPreferences NotificationPreferences?
  entries      JournalEntry[]
  commitments  Commitment[]
  tasks        Task[]
  strategies   Strategy[]
  goals        Goal[]
  chatMessages ChatMessage[]
  pushSubscriptions PushSubscription[]
  people      Person[]
  responseTracking ResponseTracking[]
  tonePreferences TonePreference[]
  drafts      JournalDraft[]
  writingStyle    UserWritingStyle?
  styleEdits      StyleEdit[]
  scheduledReminders ScheduledReminder[]
  calendarConnections CalendarConnection[]
}

// User context - background information for AI personalization
model UserContext {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  about               String?  @db.Text // Brief self-description
  lifeCircumstances   String?  @db.Text // Current life situation
  knownFactors        String[] // What they've explicitly mentioned
  suspectedFactors    String[] // Patterns that suggest challenges
  resourceConstraints String[] // Time, money, energy limitations
  workingConditions   String?  @db.Text // What helps them focus
  failurePatterns     String[] // Common ways things fall apart
  notes               String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// User success model - what conditions lead to completion
model UserSuccessModel {
  id                   String              @id @default(cuid())
  userId               String              @unique
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  complexityPreference ComplexityPreference @default(adaptive)
  completionConditions String[] // What "done" means to them
  failureConditions    String[] // What causes abandonment
  notes                String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// User engagement preferences - interaction style
model UserEngagementPreferences {
  id              String          @id @default(cuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  interactionMode InteractionMode @default(balanced)
  interestTracking Boolean        @default(true)
  autoStartChat   Boolean         @default(false) // Auto-start AI chat on entry submission
  likes           String[]        // Things user enjoys discussing
  dislikes        String[]        // Topics to avoid
  topicsTheyShare String[]        // Subjects user opens up about
  notes           String?         @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Journal entries
model JournalEntry {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  date              DateTime        @db.Date
  time              DateTime        @db.Time()
  timeContext       TimeContext
  content           String          @db.Text

  // Optional specific date/time for the entry (when user wants to log for a different time)
  specificDateTime  DateTime?       // User-specified date/time for this entry

  // Quick entry type for categorized entries
  entryType         QuickEntryType  @default(general)
  moodScore         Int?            // 1-5 for mood_check entries

  reflections       String[]        // Key reflections/insights
  conditionsPresent String[]        // Conditions noted (tired, stressed, etc.)
  aiResponse        String?         @db.Text // AI's response to this entry

  // Relations
  commitmentsMade   Commitment[]    @relation("EntryCommitments")
  tasksMade         Task[]          @relation("EntryTasks")
  chatMessages      ChatMessage[]
  draftsFromEntry   JournalDraft[]  @relation("DraftFromEntry")
  restoredFromDraft JournalDraft?   @relation("DraftRestored")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, createdAt])
  @@index([userId, entryType])
}

// Commitments
model Commitment {
  id                      String           @id @default(cuid())
  userId                  String
  user                    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  what                    String           @db.Text // The commitment description
  why                     String?          @db.Text // Underlying motivation
  complexity              Int              @default(3) // 1-5 scale
  motivationType          MotivationType   @default(intrinsic)
  status                  CommitmentStatus @default(active)

  // SMART goal components (all optional - can be fleshed out over time)
  // Specific: what exactly needs to be done (detailed version of 'what')
  specificDetails         String?          @db.Text
  // Measurable: how will we know it's done?
  successCriteria         String?          @db.Text
  // Achievable: what resources/skills are needed?
  requirements            String[]
  // Relevant: how does this connect to larger goals? (covered by 'why')
  // Time-bound: when should this be done?
  dueDate                 DateTime?
  timeframe               String?          // e.g., "this week", "by end of month"

  // Maturity tracking (0-5, calculated from filled SMART fields)
  // 0 = just captured, 5 = fully fleshed out SMART goal
  maturity                Int              @default(0)

  outcome                 String?          @db.Text // What actually happened
  conditionsWhenCompleted String[]         // Conditions present at completion
  learned                 String?          @db.Text // Lessons learned

  // Source entry relation
  sourceEntryId           String?
  sourceEntry             JournalEntry?    @relation("EntryCommitments", fields: [sourceEntryId], references: [id], onDelete: SetNull)

  // Strategy relations
  strategies              Strategy[]       @relation("CommitmentStrategies")
  // Tasks spawned from this commitment
  tasks                   Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
}

// Goals - high-level aspirations that strategies and tasks support
enum GoalStatus {
  active
  completed
  paused
  abandoned
}

model Goal {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String     // Brief title (e.g., "Develop intellectual rigor")
  description String?    @db.Text // Fuller description of what this goal means
  why         String?    @db.Text // Why this goal matters to them
  status      GoalStatus @default(active)

  // Progress tracking
  progress    Int        @default(0) // 0-100 percentage

  // Outcome
  outcome     String?    @db.Text // What actually happened
  learned     String?    @db.Text // Lessons learned

  // Relations
  strategies  Strategy[] @relation("GoalStrategies")
  tasks       Task[]     @relation("GoalTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
}

// Strategies - what approaches work or don't
model Strategy {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  strategy    String   @db.Text // Description of the strategy
  context     String   @db.Text // When/where it's applied
  complexity  Int      @default(3) // 1-5 scale

  worked      Boolean? // null = not yet determined
  notes       String?  @db.Text // Observations about effectiveness
  timesTried  Int      @default(1)
  lastTried   DateTime @default(now())

  // Related commitments
  relatedCommitments Commitment[] @relation("CommitmentStrategies")

  // Related goal (optional - unlinked strategies prompt for goal association)
  goalId      String?
  goal        Goal?    @relation("GoalStrategies", fields: [goalId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, worked])
  @@index([userId, goalId])
}

// Chat messages for conversation history
model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      String   // 'user' or 'assistant'
  content   String   @db.Text

  // Tool uses associated with this message (stored as JSON array)
  // Each tool use: { tool: string, input: object }
  toolUses  Json?    // Array of tool uses that happened before/with this message

  // Optional: tie to a journal entry
  entryId   String?
  entry     JournalEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Push notification subscriptions
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint  String   @unique
  p256dh    String   // Public key
  auth      String   // Auth secret

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// People tracking - relationships user mentions
model Person {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String           // Name or identifier for this person
  relationship    RelationshipType @default(other)
  notes           String?          @db.Text // Additional context about this person

  firstMentioned  DateTime         @default(now())
  lastMentioned   DateTime         @default(now())
  mentionCount    Int              @default(1)

  // Unresolved items related to this person
  unresolvedItems String[]         // Things user said they'd do related to this person

  // Sentiment tracking
  sentimentHistory PersonSentiment[]
  // Tasks related to this person
  tasks           Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId, lastMentioned])
}

// Sentiment history for a person
model PersonSentiment {
  id        String    @id @default(cuid())
  personId  String
  person    Person    @relation(fields: [personId], references: [id], onDelete: Cascade)

  sentiment Sentiment
  context   String?   @db.Text // What triggered this sentiment
  entryId   String?   // Optional link to the entry where this was noted

  createdAt DateTime  @default(now())

  @@index([personId, createdAt])
}

// Response feedback tracking - learns user preferences for AI responses
enum ResponseFeedback {
  helpful
  not_helpful
  too_long
  too_short
  tone_wrong
  off_topic
}

model ResponseTracking {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  messageId     String           // ID of the ChatMessage being rated
  feedback      ResponseFeedback
  context       String?          @db.Text // Optional context about why

  // Metadata about the response for learning
  responseLength    Int?         // Character count of the response
  containedQuestion Boolean?     // Did the AI ask questions?
  containedAdvice   Boolean?     // Did the AI give advice?
  containedEmpathy  Boolean?     // Did the AI express empathy?
  timeContext       TimeContext? // When this happened

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, feedback])
}

// Tone preference tracking - what communication styles work
model TonePreference {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  toneType    String   // e.g., "encouraging", "direct", "gentle", "challenging"
  score       Int      @default(0) // Positive = liked, negative = disliked
  sampleCount Int      @default(0) // How many samples contributed to this score

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, toneType])
  @@index([userId, score])
}

// Tasks - specific, actionable items (different from long-term Commitments)
// Commitments are long-term (e.g., "help keep boyfriend on track")
// Tasks are specific actions (e.g., "Call Spine and Sports at 9AM")
enum TaskStatus {
  pending
  completed
  skipped
  deferred
}

enum TaskUrgency {
  now          // Must do immediately
  today        // Should do today
  this_week    // Should do this week
  whenever     // No time pressure
}

model Task {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  what              String       @db.Text // The task description
  context           String?      @db.Text // Additional context/notes
  status            TaskStatus   @default(pending)
  urgency           TaskUrgency  @default(whenever)

  // Time-related
  dueDate           DateTime?    // Specific due date/time
  dueTime           String?      // e.g., "9AM", "when they open"
  scheduledFor      DateTime?    // When user plans to do it
  completedAt       DateTime?

  // Outcome tracking
  outcome           String?      @db.Text // What happened
  skippedReason     String?      @db.Text // Why it was skipped
  deferredTo        DateTime?    // When it was rescheduled to

  // Relationships
  relatedCommitmentId String?
  relatedCommitment   Commitment? @relation(fields: [relatedCommitmentId], references: [id], onDelete: SetNull)
  sourceEntryId       String?
  sourceEntry         JournalEntry? @relation("EntryTasks", fields: [sourceEntryId], references: [id], onDelete: SetNull)
  relatedPersonId     String?
  relatedPerson       Person?     @relation(fields: [relatedPersonId], references: [id], onDelete: SetNull)
  relatedGoalId       String?
  relatedGoal         Goal?       @relation("GoalTasks", fields: [relatedGoalId], references: [id], onDelete: SetNull)

  // Scheduled reminders for this task
  reminders           ScheduledReminder[]

  // Google Calendar event ID if synced
  calendarEventId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([userId, createdAt])
  @@index([userId, relatedGoalId])
}

// Journal drafts - saved entry content that wasn't committed
model JournalDraft {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  content   String   @db.Text
  reason    String?  // Why it was saved as draft (e.g., "new entry suggested", "navigated away")

  // If this draft was created from a chat suggestion
  sourceEntryId String?        // The entry we were chatting about when this was suggested
  sourceEntry   JournalEntry?  @relation("DraftFromEntry", fields: [sourceEntryId], references: [id], onDelete: SetNull)

  // If draft was restored to a new entry
  restoredToEntryId String?    @unique
  restoredToEntry   JournalEntry? @relation("DraftRestored", fields: [restoredToEntryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

// User writing style - learned preferences for journal entries
model UserWritingStyle {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Style characteristics learned from accepted edits
  prefersBulletPoints     Boolean @default(false)
  prefersMarkdown         Boolean @default(false)
  prefersShortSentences   Boolean @default(false)
  prefersFirstPerson      Boolean @default(true)
  prefersEmotionalDetail  Boolean @default(true)
  prefersActionItems      Boolean @default(false)
  prefersTimestamps       Boolean @default(false)

  // Vocabulary preferences
  avoidWords              String[] // Words/phrases to avoid
  preferredPhrases        String[] // Preferred expressions

  // Formatting preferences
  paragraphStyle          String?  // e.g., "short", "flowing", "structured"
  capitalizationStyle     String?  // e.g., "standard", "casual", "title_case"

  // Custom rules learned from edits
  customRules             String[] // Natural language rules

  // Sample phrases that capture their voice
  voiceSamples            String[] // Short excerpts that exemplify their style

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Style edit - tracks suggested edits and whether user accepted them
model StyleEdit {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The edit details
  originalText    String   @db.Text
  suggestedText   String   @db.Text
  editType        String   // e.g., "grammar", "clarity", "tone", "structure", "voice"
  explanation     String?  @db.Text // Why this edit was suggested

  // Source context
  sourceEntryId   String?

  // User feedback
  accepted        Boolean? // null = pending, true = accepted, false = rejected
  userFeedback    String?  // Optional feedback on why they rejected

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, accepted])
  @@index([userId, editType])
}

// Notification preferences - user settings for how they want to be notified
model NotificationPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Push notifications
  pushEnabled        Boolean @default(false)
  pushTaskReminders  Boolean @default(true)  // Remind about upcoming tasks
  pushDailyDigest    Boolean @default(false) // Morning summary of tasks

  // SMS notifications
  smsEnabled         Boolean @default(false)
  smsPhoneNumber     String? // E.164 format (+1234567890)
  smsVerified        Boolean @default(false)
  smsTaskReminders   Boolean @default(true)
  smsUrgentOnly      Boolean @default(true)  // Only "now" and "today" urgency

  // Calendar sync
  calendarEnabled    Boolean @default(false)
  calendarAutoSync   Boolean @default(true)  // Auto-create events for tasks with due dates

  // Timing preferences
  quietHoursStart    String? // e.g., "22:00" - no notifications after this
  quietHoursEnd      String? // e.g., "08:00" - notifications resume
  reminderLeadTime   Int     @default(30) // Minutes before due time to remind

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Scheduled reminders - tracks reminders scheduled via external service (QStash)
enum ReminderStatus {
  scheduled
  sent
  failed
  cancelled
}

enum ReminderChannel {
  push
  sms
  email
}

model ScheduledReminder {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // What this reminder is for
  taskId      String?
  task        Task?          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Reminder details
  channel     ReminderChannel
  scheduledFor DateTime      // When to send
  message     String         @db.Text // The reminder message

  // External scheduler tracking
  externalId  String?        // QStash message ID for cancellation
  status      ReminderStatus @default(scheduled)
  sentAt      DateTime?
  error       String?        @db.Text

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId, status])
  @@index([taskId])
  @@index([scheduledFor, status])
}

// Calendar connections - OAuth tokens for Google Calendar
model CalendarConnection {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider      String   @default("google") // "google", "outlook", etc.
  accessToken   String   @db.Text
  refreshToken  String?  @db.Text
  tokenExpiry   DateTime?
  calendarId    String?  // Primary calendar ID to use

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, provider])
}
